--- !u!114 &311765328
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 311765327}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 32e6eb538cd30bb48861f8c4abea8e76, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  textoDialogo: {fileID: 296743807}
  contenedorDialogo: {fileID: 224313706}
  baseDeDatos:
  - categoria: Inicio
    frases:
    - "\xA1Miau! Bienvenido al laboratorio, humano."
    - "\"Mis bigotes presienten que hoy ser\xE1 un d\xEDa de muchas monedas de oro.\""
  - categoria: Peligro
    frases:
    - "\xA1Cuidado! \xA1Eso va a explotar!"
    - "\"\xA1Miau! \xA1Eso burbujea de forma muy sospechosa! \xA1Haz algo!\""
    - "\"\xA1Si esto explota, espero que sepas que tengo siete vidas, pero t\xFA
      solo una!\""
    - "\"\xA1Huele a quemado! \xA1Recuerda revisar el libro!\""
    - "\"\xA1Error! \xA1Ese no era el ingrediente!\""
  - categoria: Aleatorio
    frases:
    - "\xBFHas visto mi rat\xF3n de juguete por ah\xED?\""
    - "\"\xBFHas visto mi rat\xF3n de juguete? Jurar\xEDa que lo dej\xE9 cerca de
      la Amatista...\""
    - "\"No te quedes mirando las chispas, \xA1tenemos pedidos que entregar!\""
    - "\"Si te sobra un poco de pescado, ya sabes d\xF3nde est\xE1 mi plato.\""
    - "\"\xBFRecuerdas el orden? El libro es tu mejor amigo, despu\xE9s de m\xED.\""
  velocidadEscritura: 0.05
  tiempoVisibleDespuesDeEscribir: 2.5
